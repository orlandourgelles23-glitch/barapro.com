# ===========================================
# BARAPRO v11 - Variables de Entorno
# Copie este archivo como .env y ajuste los valores
# ===========================================

# ---- Base de Datos / Database ----
# Ruta de la base de datos SQLite (relativa al directorio prisma/)
# SQLite database path (relative to prisma/ directory)
DATABASE_URL=file:../db/custom.db

# ---- Autenticación / Authentication ----
# Clave de firma JWT en formato hexadecimal (64 caracteres)
# Si no se establece, se genera automáticamente y se almacena en .auth-secret
#
# JWT signing key in hex format (64 characters)
# If not set, one is generated automatically and stored in .auth-secret
# Generar con: node scripts/generate-auth-secret.js
# AUTH_SECRET_HEX=

# ---- Servidor / Server ----
# Puerto del servidor (por defecto 3000)
# Server port (default: 3000)
# PORT=3000

# ---- Credenciales por Defecto / Default Credentials ----
# Al primer inicio, se crea un usuario admin con estas credenciales
# On first start, an admin user is created with these credentials
# Usuario/Username: admin
# Contraseña/Password: 2026
# ⚠️ CAMBIAR INMEDIATAMENTE DESPUÉS DE LA INSTALACIÓN
# ⚠️ CHANGE IMMEDIATELY AFTER INSTALLATION
